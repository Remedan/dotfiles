configuration {
{%@@ if distro == "ubuntu" @@%}
    font: "Ubuntu 12";
{%@@ else @@%}
    font: "Open Sans 12";
{%@@ endif @@%}
    terminal: "alacritty";
{%@@ if colorscheme == "gruvbox-dark" @@%}
    theme: "gruvbox-dark";
{%@@ elif colorscheme == "dracula" @@%}
    theme: "dracula";
{%@@ else @@%}
    theme: "solarized";
{%@@ endif @@%}
}
