! Font settings
URxvt.font: xft:Iosevka Term:pixelsize=12
!URxvt.letterSpace: -1

! Cursor
Xcursor.theme: Adwaita
Xcursor.size: 16

! Scrollbar
URxvt.scrollBar: true
URxvt.scrollBar_right: true
URxvt.scrollstyle: plain
{%@@ if profile == "athena" @@%}
URxvt.scrollColor: #ebdbb2
{%@@ else @@%}
URxvt.scrollColor: #093748
{%@@ endif @@%}

! Clickable links
URxvt.perl-ext-common: default,matcher
URxvt.url-launcher: /usr/bin/firefox
URxvt.matcher.button: 1

! Colours
URxvt.depth: 24
{%@@ if profile == "athena" @@%}
#include ".Xresources-include/colors-gruvbox"
{%@@ else @@%}
#include ".Xresources-include/colors-solarized-dark"
{%@@ endif @@%}

! Rofi settings
rofi.terminal: st
{%@@ if profile == "athena" @@%}
#include ".Xresources-include/rofi-gruvbox"
{%@@ else @@%}
#include ".Xresources-include/rofi-solarized-dark"
{%@@ endif @@%}
