# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=rem-lambda
ENABLE_CORRECTION="true"
plugins=(
    git
    docker
    docker-compose
    kubectl
    pip
    virtualenvwrapper
    zsh-autosuggestions
    shrink-path
)
source $ZSH/oh-my-zsh.sh

{%@@ if colorscheme == "solarized-dark" @@%}
# zsh-autosuggestion isn't visible with solarized dark
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=60'
{%@@ endif @@%}

# Add useful directories to path
export PATH="$HOME/scripts:$PATH"
export PATH="$HOME/.local/bin:$PATH"

# Set EDITOR to neovim if it's installed
if command -v nvim > /dev/null
then
    export EDITOR=nvim
fi

# Useful aliases
alias sxiv='sxiv -a'
alias sudo='sudo -E'
alias ip='ip -c'
alias wine32='WINEARCH=win32 WINEPREFIX=~/.wine32 wine'

# Git aliases
alias gs='git status'
alias ga='git add'
alias gb='git branch'
alias gc='git commit'
alias gd='git diff'
alias gdc='git diff --cached'
alias go='git checkout'
alias gh='git hist'
alias gp='git pull'
alias gu='git push'
alias gm='git merge'
alias gl='git log'

# Set up virtualenvwrapper
{%@@ if distro == "ubuntu" @@%}
{%@@ set path = "/usr/local/bin" @@%}
{%@@ else @@%}
{%@@ set path = "/usr/bin" @@%}
{%@@ endif @@%}
if [ -f {{@@ path @@}}/virtualenvwrapper.sh ]
then
    export WORKON_HOME=~/.virtualenvs
{%@@ if profile == "dev-pc-28" @@%}
    export VIRTUALENVWRAPPER_PYTHON=$(which python3.8)
{%@@ endif @@%}
    source {{@@ path @@}}/virtualenvwrapper.sh
fi

# Needed for YubiKey + ssh
export GPG_TTY="$(tty)"
export SSH_AUTH_SOCK=$(gpgconf --list-dirs agent-ssh-socket)
gpgconf --launch gpg-agent
